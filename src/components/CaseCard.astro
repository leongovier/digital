---
import CaseArt from './CaseArt.astro';

export interface Props {
  href: string;
  title: string;
  description: string;
  tag: string;
  cardArt?: 'laptop' | 'mobile' | 'grid' | 'type';
  revealDelay?: '' | 'd1' | 'd2' | 'd3';
}

const { href, title, description, tag, cardArt = 'laptop', revealDelay = '' } = Astro.props;
---

<a href={href} class={`case reveal ${revealDelay}`}>
  <div class="case-frame">
    <CaseArt variant={cardArt} />
  </div>
  <div class="case-meta">
    <div>
      <div class="case-title">
        {title} <span class="case-arrow">↗</span>
      </div>
      <div class="case-desc">{description}</div>
    </div>
    <div class="case-tag">{tag}</div>
  </div>
</a>
