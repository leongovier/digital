---
export interface Props {
  src: string;
  alt: string;
  url: string;
  urlAccent?: string;
  caption?: string;
  captionLabel?: string;
  /** When true, lays out as part of a two-up grid (no .wrap or .shot-wide). */
  inline?: boolean;
}

const {
  src,
  alt,
  url,
  urlAccent,
  caption,
  captionLabel,
  inline = false,
} = Astro.props;
---

{
  inline ? (
    <div>
      <div class="browser">
        <div class="browser-bar">
          <div class="browser-dots"><span /><span /><span /></div>
          <div class="browser-url">
            {url}
            {urlAccent && <span class="accent">{urlAccent}</span>}
          </div>
        </div>
        <img src={src} alt={alt} loading="lazy" />
      </div>
      {caption && (
        <div class="shot-cap">
          <span class="arrow">→</span>
          <span>
            {captionLabel && <b>{captionLabel}</b>}
            {captionLabel && ' · '}
            {caption}
          </span>
        </div>
      )}
    </div>
  ) : (
    <div class="wrap">
      <div class="shot-wide">
        <div class="browser">
          <div class="browser-bar">
            <div class="browser-dots"><span /><span /><span /></div>
            <div class="browser-url">
              {url}
              {urlAccent && <span class="accent">{urlAccent}</span>}
            </div>
          </div>
          <img src={src} alt={alt} loading="lazy" />
        </div>
        {caption && (
          <div class="shot-cap">
            <span class="arrow">→</span>
            <span>
              {captionLabel && <b>{captionLabel}</b>}
              {captionLabel && ' · '}
              {caption}
            </span>
          </div>
        )}
      </div>
    </div>
  )
}
