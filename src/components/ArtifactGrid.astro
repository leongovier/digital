---
export interface FlowNode {
  label: string;
  accent?: boolean;
}

export interface ArtifactItem {
  kind: 'sketches' | 'flow';
  caption: string;
  nodes?: FlowNode[];
  aspect?: string;
}

export interface Props {
  items: ArtifactItem[];
  layout?: 'pair' | 'single';
}

const { items, layout = 'pair' } = Astro.props;
const gridStyle = layout === 'single' ? 'grid-template-columns: 1fr;' : '';
---

<div class="wrap">
  <div class="artifacts" style={gridStyle}>
    {
      items.map((item) => (
        <div>
          <div
            class="artifact"
            style={item.aspect ? `aspect-ratio: ${item.aspect};` : ''}
          >
            {item.kind === 'sketches' && (
              <div class="sketch-bg">
                <div class="sketch-card">
                  <div class="sketch-line short" />
                  <div class="sketch-line accent" />
                  <div class="sketch-box" />
                </div>
                <div class="sketch-card">
                  <div class="sketch-line short" />
                  <div class="sketch-line" />
                  <div class="sketch-box" />
                </div>
                <div class="sketch-card">
                  <div class="sketch-line short" />
                  <div class="sketch-line" />
                  <div class="sketch-box" />
                </div>
                <div class="sketch-card">
                  <div class="sketch-line short" />
                  <div class="sketch-line accent" />
                  <div class="sketch-box" />
                </div>
              </div>
            )}

            {item.kind === 'flow' && item.nodes && (
              <div class="flow-bg">
                <div class="flow">
                  {item.nodes.map((node, i) => (
                    <Fragment>
                      <div class={`flow-node ${node.accent ? 'accent' : ''}`}>
                        {node.label}
                      </div>
                      {i < (item.nodes!.length - 1) && (
                        <div class="flow-arrow">→</div>
                      )}
                    </Fragment>
                  ))}
                </div>
              </div>
            )}
          </div>
          <div class="artifact-caption">{item.caption}</div>
        </div>
      ))
    }
  </div>
</div>
