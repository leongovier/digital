---
// v2 nav — floating glass pill, matches the home page. Used on case-study
// detail pages; links point back to the home sections.
import Brand from './Brand.astro';

export interface Props {
  variant?: 'home' | 'detail';
}

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/#case-studies', label: 'Case studies' },
  { href: '/#process', label: 'Process' },
  { href: '/#tools', label: 'Tools' },
  { href: '/#timeline', label: 'Timeline' },
  { href: '/#gallery', label: 'Gallery' },
  { href: '/#feedback', label: 'Feedback' },
];
---

<nav class="nav" aria-label="Primary">
  <Brand href="/" />
  <ul>
    {navLinks.map((l) => (
      <li><a class="link" href={l.href}>{l.label}</a></li>
    ))}
  </ul>
  <a class="cta" href="/#contact">
    Contact
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
  </a>
</nav>

<style>
  .nav {
    position: sticky;
    top: 16px;
    width: calc(100% - 56px);
    max-width: 1240px;
    margin: 16px auto 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px 10px 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 8px 32px -16px rgba(14, 18, 25, 0.18);
  }
  .nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav .link {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: 999px;
    font-family: 'Inter Tight', 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
    color: #1a1d26;
    text-decoration: none;
    transition: color .2s;
  }
  .nav .link::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(245, 166, 35, 0.2);
    border-radius: 999px;
    transform: translateX(-101%);
    transition: transform .28s cubic-bezier(.2, .8, .2, 1);
  }
  .nav .link:hover::before { transform: translateX(0); }
  .nav .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f5a623;
    color: #fff;
    padding: 9px 16px;
    border-radius: 999px;
    font-family: 'Inter Tight', 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: transform .2s, background .2s;
  }
  .nav .cta:hover { background: #ea4a14; transform: translateY(-1px); }
  @media (max-width: 880px) {
    .nav ul { display: none; }
  }
</style>
