---
export interface DecisionItem {
  title: string;
  body: string;
}

export interface Props {
  keptLabel?: string;
  cutLabel?: string;
  keptHeading?: string;
  cutHeading?: string;
  kept: DecisionItem[];
  cut: DecisionItem[];
}

const {
  keptLabel = 'Kept',
  cutLabel = 'Cut',
  keptHeading = 'what made the cut',
  cutHeading = "what didn't survive contact",
  kept,
  cut,
} = Astro.props;
---

<div class="narrow">
  <div class="decisions">
    <div class="decision-col kept">
      <h4><span class="label">{keptLabel}</span> — {keptHeading}</h4>
      <ul>
        {
          kept.map((it) => (
            <li>
              {it.title}
              <small>{it.body}</small>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="decision-col cut">
      <h4><span class="label">{cutLabel}</span> — {cutHeading}</h4>
      <ul>
        {
          cut.map((it) => (
            <li>
              {it.title}
              <small>{it.body}</small>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</div>
