---
export interface GalleryShot {
  kind: 'app' | 'form' | 'detail';
  caption: string;
  full?: boolean;
  variant?: 'stats' | 'table';
  sideActive?: number;
  submitLabel?: string;
}

export interface Props {
  shots: GalleryShot[];
}

const { shots } = Astro.props;
---

<div class="wrap">
  <div class="gallery">
    {
      shots.map((shot) => {
        const sideActive = shot.sideActive ?? 1;
        const variant = shot.variant ?? 'stats';
        return (
          <div class={shot.full ? 'full' : ''}>
            <div class={`shot ${shot.full ? 'full' : ''}`}>
              {shot.kind === 'app' && (
                <div class="shot-app">
                  <div class="side">
                    {[1, 2, 3, 4].map((i) => (
                      <div class={`side-item ${sideActive === i ? 'on' : ''}`} />
                    ))}
                    <div class="side-item" style="margin-top: auto" />
                  </div>
                  <div class="main">
                    {variant === 'stats' ? (
                      <Fragment>
                        <div class="header-row">
                          <div class="h-pill title" />
                          <div style="flex: 1" />
                          <div class="h-pill s" />
                          <div class="h-pill s" />
                        </div>
                        <div class="grid">
                          <div class="stat-card"><div class="lbl" /><div class="val" /></div>
                          <div class="stat-card hl"><div class="lbl" /><div class="val" /></div>
                          <div class="stat-card"><div class="lbl" /><div class="val" /></div>
                          <div class="stat-card"><div class="lbl" /><div class="val" /></div>
                        </div>
                        <div class="table-rows">
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                        </div>
                      </Fragment>
                    ) : (
                      <Fragment>
                        <div class="header-row">
                          <div class="h-pill title" />
                          <div style="flex: 1" />
                          <div class="h-pill s" />
                        </div>
                        <div class="table-rows">
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                          <div class="row-r" />
                        </div>
                      </Fragment>
                    )}
                  </div>
                </div>
              )}

              {shot.kind === 'form' && (
                <div class="shot-form">
                  <div class="form-h" />
                  <div class="form-row"><div class="form-label" /><div class="form-input" /></div>
                  <div class="form-row"><div class="form-label" /><div class="form-input focus" /></div>
                  <div class="form-row"><div class="form-label" /><div class="form-input" /></div>
                  <div class="form-row"><div class="form-label" /><div class="form-input" /></div>
                  <div class="submit">{shot.submitLabel ?? 'Save audit'}</div>
                </div>
              )}

              {shot.kind === 'detail' && (
                <div class="shot-detail">
                  <div class="crumb" />
                  <div class="body-grid">
                    <div class="col">
                      <div class="blk accent" />
                      <div class="blk tall" />
                      <div class="blk" />
                      <div class="blk" />
                    </div>
                    <div class="col">
                      <div class="blk" />
                      <div class="blk tall" />
                      <div class="blk" />
                    </div>
                  </div>
                </div>
              )}
            </div>
            <div class="artifact-caption">{shot.caption}</div>
          </div>
        );
      })
    }
  </div>
</div>
