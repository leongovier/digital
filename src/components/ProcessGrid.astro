---
export interface ProcessStep {
  num: string;
  title: string;
  body: string;
}

export interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
---

<div class="wrap">
  <div class="process-grid">
    {
      steps.map((step) => (
        <div class="process-step">
          <div class="n">{step.num}</div>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </div>
      ))
    }
  </div>
</div>
