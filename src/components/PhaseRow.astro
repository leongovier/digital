---
export interface Phase {
  name: string;
  pct: number;
  accent?: boolean;
}

export interface Props {
  phases: Phase[];
}

const { phases } = Astro.props;
---

<div class="phase-row">
  {
    phases.map((p) => (
      <div class="phase">
        <span class="phase-name">{p.name}</span>
        <span class={`phase-pct ${p.accent ? 'accent' : ''}`}>{p.pct}%</span>
      </div>
    ))
  }
</div>
