const navLinks = [
  { href: '#top', label: 'Home' },
  { href: '#case-studies', label: 'Case studies' },
  { href: '#process', label: 'Process' },
  { href: '#tools', label: 'Tools' },
  { href: '#timeline', label: 'Timeline' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#feedback', label: 'Feedback' },
];

const arrowSvg =
  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';

const title = 'Leon Govier — Product Designer & Builder';
const description =
  'Leon Govier — an AI-native Product Designer & Builder shipping digital products at speed. Selected work, process, and tools.';
const canonical = 'https://portfolio.leongovier.com/';
const ogImage = 'https://portfolio.leongovier.com/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Leon Govier" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Leon Govier" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800&family=Quicksand:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Fixed background shape layer — animates with page scroll -->
    <div class="shape-layer" aria-hidden="true">
      <div class="shape hero-bg-shape-1"></div>
      <div class="shape hero-bg-shape-2"></div>
      <div class="shape hero-bg-shape-3"></div>
      <div class="shape hero-bg-shape-4"></div>
      <div class="shape hero-bg-shape-5"></div>
      <div class="shape hero-bg-shape-6"></div>
    </div>

    <!-- ============================== NAV ============================== -->
    <nav class="nav" aria-label="Primary">
      <Brand href="#top" />
      <ul>
        {
          navLinks.map((l) => (
            <li>
              <a class={l.href === '#top' ? 'link active' : 'link'} href={l.href}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a class="cta" href="#contact">
        Contact
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
    </nav>

    <!-- ============================== HERO ============================== -->
    <section id="top" class="hero">
      <div class="wrap">
        <div>
          <h1>
            Designing <span class="accent">delightful</span> and
            <span class="accent">useful</span><br />
            digital products for real users
          </h1>
          <p class="lede" style="margin-top:28px;">
            Currently Product Designer &amp; Builder working with teams that need
            to move quickly. Design. Prompt. Prototype. Ship.
          </p>
          <div class="meta">
            <span class="rule"></span>
            <a class="social" href="https://www.linkedin.com/in/leongovier/" aria-label="LinkedIn" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.7h.06c.53-1 1.83-2.05 3.77-2.05C21.6 8.65 22 11.05 22 14.1V21h-4v-6.1c0-1.45-.03-3.3-2.02-3.3-2.03 0-2.34 1.58-2.34 3.2V21h-4V9Z"></path></svg>
            </a>
            <a class="social" href="mailto:hello@leongovier.com" aria-label="Email">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== CASE STUDIES ============================== -->
    <section id="case-studies" class="shipped section-pad" style="padding:12px 0 120px;">
      <div class="wrap">
        <div class="section-head">
          <div>
            <span class="eyebrow dot">Selected work over the last 5 years</span>
            <h2>Things I've <span class="accent">shipped</span>.</h2>
          </div>
          <div class="tail">
            Nine projects, one through-line — <b>complex products shipped under
            real constraints.</b> The variable is scale. Some are AI-native MVPs designed,
            prompted and built solo in a month — Cubik's lending platform, a
            reverse-matching CRM for a car dealer. Others are design systems
            absorbed into enterprise platforms already serving thousands — Jamf,
            CWT, Coincover. Fintech and specialist lending run through most of it;
            conversational quote engines, mortgage affordability, pricing
            calculators. Different domains, same job: make the complex usable.
          </div>
        </div>

        <div class="case-grid">
          <!-- Feature card -->
          <article class="case feature">
            <div class="case-body">
              <div class="shot">
                <img src={featureCase.img} alt={featureCase.alt} loading="lazy" />
              </div>
              <div class="case-text">
                <div class="tag-row">
                  {
                    featureCase.tags.map((t, i) => (
                      <Fragment>
                        {i > 0 && <span class="dot">·</span>}
                        {t}
                      </Fragment>
                    ))
                  }
                </div>
                <h3>{featureCase.title}</h3>
                <p>{featureCase.body}</p>
                <a class="view" href={featureCase.href}>
                  View Case Study
                  <Fragment set:html={arrowSvg} />
                </a>
              </div>
            </div>
          </article>

          {
            gridCases.map((c) => (
              <article class="case">
                <div class="shot">
                  <img src={c.img} alt={c.alt} loading="lazy" />
                </div>
                <div class="tag-row">
                  {c.tags.map((t, i) => (
                    <Fragment>
                      {i > 0 && <span class="dot">·</span>}
                      {t}
                    </Fragment>
                  ))}
                </div>
                <h3>{c.title}</h3>
                <p>{c.body}</p>
                <a class="view" href={c.href}>
                  View Case Study
                  <Fragment set:html={arrowSvg} />
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================== WORKFLOW ============================== -->
    <section id="process" class="workflow section-pad">
      <div class="wrap">
        <span class="eyebrow dot">How I work</span>
        <h2 style="margin-top:16px;">
          Two diamonds. <span class="accent">One AI-powered</span> workflow.
        </h2>
        <p class="lede">
          The methodology stays constant — Double Diamond, always. What changes
          project-to-project is the phase weighting. Domain expertise lets me
          compress discovery. MCP and Claude Code accelerate build. Senior
          judgement is knowing where to speed up and where to slow down. I design
          in Figma, Claude reads it via MCP and generates production code, the
          fidelity gap collapses.
          <b>AI as co-pilot, not autopilot — I choose when to use it, and where deterministic logic beats LLM guesswork.</b>
        </p>

        <div class="steps">
          {
            steps.map((s) => (
              <div class="step">
                <div class="num">{s.num}</div>
                <h3>
                  <span class="accent">{s.chevron}</span>
                  <span class="step-title">{s.title}</span>
                </h3>
                <div class="step-row">
                  <p>{s.body}</p>
                  <svg class="gauge" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="rgba(14,18,25,0.15)" stroke-width="3" />
                    <circle cx="18" cy="18" r="15.5" fill="none" stroke="var(--ember)" stroke-width="3" stroke-dasharray={s.dash} stroke-linecap="round" transform="rotate(-90 18 18)" />
                    <text x="18" y="20" text-anchor="middle" font-family="Inter Tight" font-size="6.5" fill="var(--ink)">
                      {s.pct}
                    </text>
                  </svg>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================== TOOLS ============================== -->
    <section id="tools" class="tools section-pad">
      <div class="wrap">
        <div class="section-head">
          <div>
            <span class="eyebrow dot">Tools &amp; Stack</span>
            <h2>The tools I reach for.</h2>
          </div>
          <div class="tail">
            The stack has shifted hard toward AI. Claude, Claude Code and Claude
            Design now sit at the centre of how I work — design, prompt, build,
            test. Figma stays the design surface; MCP bridges it to production
            code. The rest is what holds up under delivery — TypeScript, Astro,
            Tailwind, a Double Diamond process. Chosen for speed, quality, and how
            well they play together.
          </div>
        </div>

        <div class="tools-grid">
          {
            toolCategories.map((cat) => (
              <div class="tool-cat">
                <span class="eyebrow">{cat.name}</span>
                <div class="chips">
                  {cat.chips.map((chip) => (
                    <span class="chip">{chip.label}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================== TIMELINE ============================== -->
    <section id="timeline" class="timeline section-pad">
      <div class="wrap">
        <div class="section-head">
          <div>
            <span class="eyebrow dot">Career</span>
            <h2>Years of <span class="accent">shipping</span>, in roughly the right order.</h2>
          </div>
          <div class="tail">
            Twelve years on this timeline, more behind it. The shape repeats —
            join a business, build the UX function or design system it's missing,
            raise the bar, move on. In-house leadership at William Hill and Pepper
            Money. Contract transformations at TrakCel, CWT and Coincover. A
            platform redesign at Jamf. Lately, AI-native product work at Cubik and
            beyond. Different industries, same job: make complex platforms work
            for the people using them.
          </div>
        </div>

        <div class="tl-track">
          <div class="tl-line"></div>
          <div class="tl-stops">
            {
              timeline.map((stop) => (
                <button
                  type="button"
                  class={stop.current ? 'tl-stop active' : 'tl-stop'}
                  aria-pressed={stop.current ? 'true' : 'false'}
                >
                  <span class="node"></span>
                  <div class="tl-content">
                    <div class="label">{stop.label}</div>
                    <div class="range">{stop.range}</div>
                  </div>
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== GALLERY ============================== -->
    <section id="gallery" class="gallery section-pad">
      <div class="wrap">
        <div class="section-head">
          <div>
            <span class="eyebrow dot">Selected work</span>
            <h2>Not everything is a <span class="accent">complex data</span> dashboard.</h2>
          </div>
          <div class="tail">
            Not every project is an enterprise platform. This is the lighter side
            of the work — consumer apps, mobile products and branding for smaller
            clients. A property finder, a fractional-investment app, a vegetarian
            food guide, an Apple Watch companion for horseracing, an airline
            onboarding flow. Different scale, different briefs — but the same
            instinct: find the simple shape inside the problem.
          </div>
        </div>

        <div class="g-grid">
          {
            gallery.map((g) => (
              <div class="g-card">
                <div class="shot">
                  {g.img && <img src={g.img} alt={g.label} loading="lazy" />}
                </div>
                <div class="label">
                  <span class="arrow">↗</span> {g.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============================== FEEDBACK ============================== -->
    <section id="feedback" class="feedback section-pad">
      <div class="wrap">
        <div class="fb-head">
          <div>
            <span class="eyebrow dot">Feedback received</span>
            <p class="section-desc">
              Twelve recommendations gathered over the years from the people on
              the other side of the work — chief officers, product directors,
              design leads and engineers. Different companies, different briefs,
              but the themes recur: clarity under pressure, design that holds up
              after launch, and someone equally at home in a stakeholder room or
              deep in the detail. Their words, not mine.
            </p>
          </div>
          <div class="fb-controls">
            <button class="fb-btn" data-dir="prev" aria-label="Previous">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 18l-6-6 6-6"></path></svg>
            </button>
            <button class="fb-btn active" data-dir="next" aria-label="Next">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            </button>
          </div>
        </div>

        <div class="fb-rail-wrap">
          <div class="fb-rail" id="fbRail">
            {
              feedback.map((f) => (
                <div class="fb-card">
                  <div class="quote-mark">"</div>
                  <p>{f.quote}</p>
                  <div class="who">
                    <b>{f.name}</b>
                    {f.role}
                    {f.company && (
                      <Fragment>
                        {' · '}
                        <a href="#">{f.company}</a>
                      </Fragment>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== CTA ============================== -->
    <section id="contact" class="cta">
      <div class="wrap">
        <span class="eyebrow dot">Say hello</span>
        <h2 style="margin-top:24px;">
          Got something <span class="accent">interesting</span><br />to build?
        </h2>
        <p class="section-desc">
          Open to product design and build work — whole projects, fractional
          engagements, or just a conversation to start.
        </p>

        <div class="cta-row">
          <a class="cta-btn" href="mailto:hello@leongovier.com">
            hello@leongovier.com
            <span class="arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            </span>
          </a>
          <a class="cta-link" href="https://www.linkedin.com/in/leongovier/" target="_blank" rel="noopener">
            Connect on LinkedIn →
          </a>
        </div>
      </div>
    </section>

    <footer class="foot">
      <div class="wrap">
        <span>© 2026 Leon Govier — built &amp; designed in-house with <span class="accent">Claude AI</span></span>
        <span>Last updated <span class="accent">May 2026</span></span>
      </div>
    </footer>

    <script>
      import '../scripts/home.ts';
    </script>
  </body>
</html>
