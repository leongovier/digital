---
import Brand from '../components/Brand.astro';
import '../styles/home.css';

/* ---------- Content ---------- */

interface CaseStudy {
  num: string;
  title: string;
  tags: string[];
  body: string;
  href: string;
  img: string;
  alt: string;
  feature?: boolean;
}

const cases: CaseStudy[] = [
  {
    num: '01',
    title: 'checkRR',
    tags: ['SAAS', 'WEBSITE', 'PWA', 'BRANDING', 'DESIGN SYSTEM'],
    body: 'checkRR turns mortgage affordability checks into a guided 5-minute applicant flow. Applicants — PAYE or self-employed — upload three months of payslips and statements themselves, and the product verifies income against ONS benchmarks to return a clear affordability and DTI picture. Brokers get that verified data instantly through a white-label dashboard, instead of chasing paperwork for a week. Shipped end to end: marketing site, installable PWA, brand identity, and the design system underneath.',
    href: '/work/checkrr',
    img: '/case-studies/checkrr/home-card.webp',
    alt: 'checkRR — marketing site and applicant product',
    feature: true,
  },
  {
    num: '02',
    title: 'Cubik CRM',
    tags: ['SAAS', 'CRM', 'PIPELINE', 'SPECIALIST LENDING'],
    body: "The broker workspace for Cubik's specialist-lending suite — the AI quote engine embedded straight into pipeline and lead management, so brokers generate indicative quotes and track cases from enquiry to completion without switching tools. A four-week solo build: designed, prompted and shipped with Claude Design and Claude Code.",
    href: '/work/cubik-crm',
    img: '/case-studies/cubik-crm/slider/01.webp',
    alt: 'Cubik CRM dashboard',
  },
  {
    num: '03',
    title: 'Cubik AI',
    tags: ['AI', 'CONVERSATIONAL UX', 'QUOTE ENGINE', 'SPECIALIST LENDING'],
    body: 'A turn-by-turn chat that builds an indicative commercial quote alongside a structured form. Bridging and Commercial Buy-to-Let, indicative quotes in under 60 seconds, full audit trail. Designed, prompted, prototyped and shipped using Claude Design, Claude chat and Claude Code as the production pipeline.',
    href: '/work/cubik-ai',
    img: '/case-studies/cubik-ai/calculator-card.webp',
    alt: 'Cubik AI conversational quote interface',
