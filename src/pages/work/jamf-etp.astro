---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/jamf-etp/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/jamf-etp/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/jamf-etp/slider/${f}`);
---

<BaseLayout
  title="Jamf Executive Threat Protection — Case Study"
  description="A contract engagement at Jamf — absorbed a newly acquired mobile threat defence platform into Jamf's design system, redesigned a high-stakes security console, and contributed new patterns back into the broader system."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">Jamf ETP</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              Jamf Executive Threat Protection is a mobile threat defence platform serving
              security teams across government, law enforcement, and high-value-individual
              protection. The engagement absorbed a newly acquired product into Jamf's existing
              design system, redesigned a complex security console handling threat intelligence,
              forensics, and fleet-scale triage, and contributed new patterns back into the
              broader Jamf design system.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>Long-form contract engagement</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">Jamf design system</span>
              <span class="tpl-meta-chip">React</span>
              <span class="tpl-meta-chip">Maze</span>
              <span class="tpl-meta-chip">Jira</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd class="tpl-meta-clamp">Redesigned and integrated security platform shipped to production as part of the Jamf suite — reduced cognitive load, ecosystem alignment, and design system contributions adopted at Jamf level</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd class="tpl-meta-clamp">Acquired-product full UX integration, design system contributions adopted at Jamf level, sole-designer ownership of a high-stakes security console, fleet-scale triage workflows</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="/work/coincover" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="#" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class={`tpl-content ${sliderImages.length === 0 ? 'is-empty-slider' : ''}`}>
        {sliderImages.length > 0 && (
          <div class="tpl-slider" data-slider data-autoplay="8000">
            <div class="tpl-slider-track" data-slider-track>
              {sliderImages.map((src, i) => (
                <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                  <img
                    src={src}
                    alt={`Slide ${i + 1}`}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    data-lightbox="checkrr"
                  />
                </div>
              ))}
            </div>

            {sliderImages.length > 1 && (
              <>
                <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M15 18l-6-6 6-6" />
                  </svg>
                </button>
                <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </button>
                <div class="tpl-slider-dots" data-slider-dots>
                  {sliderImages.map((_, i) => (
                    <button
                      type="button"
                      class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                      data-slide-index={i}
                      aria-label={`Go to slide ${i + 1}`}
                    ></button>
                  ))}
                </div>
              </>
            )}
          </div>
        )}

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">Absorbing a newly acquired security platform into a public-company design system</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              A newly acquired mobile threat defence platform operating as a functionally separate
              product inside Jamf — its own design language, IA, and conventions, none aligned to
              the rest of the suite. The existing UI couldn't support the operational pace its
              security teams worked at.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/jamf-etp/slider/03.webp"
              alt="Jamf ETP product surface — Discover phase"
            />
          </figure>
          <p>
            Discovery established two layered problems. The first was integration: <strong>the
            acquired product needed to feel like part of Jamf, not a separate tool stitched into
            the suite</strong>. Customers moving between fleet management, security, and threat
            response expected consistent interaction patterns and visual language. Every
            inconsistency added cognitive cost on top of the inherent stress of high-stakes
            security work.
          </p>
          <p>
            The second was substance. The product handled threat intelligence feeds, device-level
            forensics, alert triage, compliance reporting, and fleet management at scale — a full
            security console for users who couldn't afford to miss a signal or misread an alert.
            A third discovery shaped the approach: Jamf's existing design system couldn't fully
            absorb the complexity of this product's data. Patterns for threat intelligence,
            forensic investigation, and high-density operational telemetry didn't yet exist. The
            work would require extending the system, not just consuming it.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              In an acquired-product integration, the real work isn't visual alignment — it's
              understanding which parts of the parent design system can absorb the new product
              as-is, and which parts need to be extended to support what the new product actually
              does.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">Extending the Jamf design system to handle high-density security workflows</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Define an integration approach that aligned the acquired platform with the wider
              Jamf suite while extending the design system with patterns for threat intelligence,
              forensics, and fleet-scale operational data.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/jamf-etp/slider/05.webp"
              alt="Jamf ETP product surface — Define phase"
            />
          </figure>
          <p>
            The strategy set on two principles: <strong>align everything that should align, and
            extend the system where it genuinely couldn't stretch</strong>. Navigation, UI shell,
            typography, base components, and global interaction patterns aligned to the existing
            Jamf system without modification — consistency with the suite was non-negotiable.
          </p>
          <p>
            The data-heavy surfaces — threat intelligence feeds, device-level forensic detail,
            alert triage queues, fleet-wide compliance views — needed new patterns the existing
            system didn't have. These were defined as extensions to the Jamf design system, not
            local-only solutions. Patterns for severity hierarchies, signal-vs-noise filtering,
            investigation drill-downs, and dense operational layouts were designed to be
            contributed back upstream — usable by future products inside the suite. Accessibility
            followed Jamf's existing standards by default; the extensions inherited contrast,
            focus state, and keyboard navigation patterns from the system they were aligning to.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The strongest integration work doesn't just consume the parent design system — it
              identifies where the system needs to grow and contributes that growth back, leaving
              the entire ecosystem stronger than it was before.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">Sole-designer ownership of a high-stakes security console</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deliver the full redesign across threat intelligence, forensics, triage, compliance,
              and fleet management surfaces — as sole designer, partnering closely with
              engineering and product to ship to production.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/jamf-etp/slider/07.webp"
              alt="Jamf ETP product surface — Develop phase"
            />
          </figure>
          <p>
            Development was structured around <strong>working independently on the acquired
            platform while partnering closely with the wider Jamf design and engineering
            organisation</strong> for system contributions and cross-product alignment. As sole
            designer, ownership was end-to-end — discovery, IA, interaction design, UI,
            prototyping, testing, and engineering handover.
          </p>
          <p>
            The threat intelligence and triage surfaces were highest-stakes: admins needed to scan
            large telemetry volumes and identify what mattered in seconds. Severity hierarchies
            were rebuilt with stricter visual rules; filter and sort patterns redesigned for rapid
            signal-vs-noise discrimination; triage queues re-architected to put highest-priority
            work at the top by default. Forensic depth was handled through progressive
            disclosure — summary-first scannability with comprehensive detail one level deeper,
            so fast triage and deep investigation could share the same canvas. Throughout
            development, new patterns were proposed and contributed back into the Jamf design
            system itself rather than kept local — strengthening the ecosystem, not just the
            product.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Sole-designer ownership of a complex enterprise product isn't isolation — it's
              about being deeply embedded in the product while staying constantly connected to
              the wider design organisation, so the work strengthens the system rather than
              diverging from it.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">A redesigned security platform shipped as a native part of the Jamf suite</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Ship the redesigned platform to production as part of the Jamf suite — with
              measurable improvements in cognitive load, ecosystem alignment, and design system
              contributions adopted at Jamf level.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/jamf-etp/slider/09.webp"
              alt="Jamf ETP product surface — Deliver phase"
            />
          </figure>
          <p>
            The engagement delivered <span class="accent">the redesigned Jamf Executive Threat
            Protection platform shipped to production</span> as a native, integrated part of the
            Jamf product suite. Threat intelligence, forensics, triage, compliance, and fleet
            management surfaces were redesigned, aligned to the wider Jamf design language, and
            extended where the existing system couldn't stretch.
          </p>
          <p>
            Measurable impact: <span class="accent">reduced cognitive load for security
            admins</span> managing large fleets, particularly in triage and threat intelligence
            surfaces. <span class="accent">Improved alignment with the wider Jamf product
            suite</span> meant customers moved between products with consistent navigation,
            interaction, and visual language.
          </p>
          <p>
            The strongest long-term outcome was structural rather than visual. <strong>New
            patterns and components developed for this platform were contributed back into the
            Jamf design system</strong> — extending the system's vocabulary for high-density
            operational data, severity hierarchies, and forensic investigation flows. The
            acquisition wasn't just absorbed into Jamf; Jamf's design system was matured by the
            acquisition.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The strongest measure of an acquired-product integration isn't whether the new
              product now looks like the parent — it's whether the parent's design system is more
              capable than it was before the acquisition landed.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>
