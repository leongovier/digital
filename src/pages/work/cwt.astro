---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/cwt/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/cwt/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/cwt/slider/${f}`);
---

<BaseLayout
  title="CWT — Case Study"
  description="An 8-month contract engagement leading UX for CWT's Data & Analytics function — built a tokenised analytics design system from zero, shipped dashboards across five data domains, and embedded a structured Zeplin/Storybook handover practice."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">CWT</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              CWT (Carlson Wagonlit Travel) is a global business travel management company. Led
              UX for the Data & Analytics function, designing internal dashboards across spend,
              traveller behaviour, sustainability, supplier performance, and duty-of-care
              reporting — and built a tokenised analytics design system from zero, embedding data
              viz capability into a team that hadn't worked at that level before.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>8-month contract engagement</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">Storybook</span>
              <span class="tpl-meta-chip">Zeplin</span>
              <span class="tpl-meta-chip">Maze</span>
              <span class="tpl-meta-chip">Jira</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd class="tpl-meta-clamp">Dashboards and design system patterns shipped to production — established a reusable analytics design system, raised the team's data viz capability, and embedded a structured handover practice</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd class="tpl-meta-clamp">Tokenised analytics design system from zero, dashboards across 5 data domains shipped, structured Zeplin/Storybook handover, continued team practice after engagement end</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="/work/jamf-etp" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="#" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class={`tpl-content ${sliderImages.length === 0 ? 'is-empty-slider' : ''}`}>
        {sliderImages.length > 0 && (
          <div class="tpl-slider" data-slider data-autoplay="8000">
            <div class="tpl-slider-track" data-slider-track>
              {sliderImages.map((src, i) => (
                <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                  <img
                    src={src}
                    alt={`Slide ${i + 1}`}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    data-lightbox="checkrr"
                  />
                </div>
              ))}
            </div>

            {sliderImages.length > 1 && (
              <>
                <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M15 18l-6-6 6-6" />
                  </svg>
                </button>
                <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </button>
                <div class="tpl-slider-dots" data-slider-dots>
                  {sliderImages.map((_, i) => (
                    <button
                      type="button"
                      class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                      data-slide-index={i}
                      aria-label={`Go to slide ${i + 1}`}
                    ></button>
                  ))}
                </div>
              </>
            )}
          </div>
        )}

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">A data and analytics function without the design foundations to scale</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              CWT's Data & Analytics function produced dashboards across five critical business
              domains — travel spend, traveller behaviour, sustainability, supplier performance,
              and duty-of-care — but had no design system, no established data visualisation
              patterns, and no structured design-to-development workflow.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cwt/slider/03.webp"
              alt="CWT product surface — Discover phase"
            />
          </figure>
          <p>
            Discovery surfaced inconsistent dashboards across five domains — different visual
            languages, different chart conventions — and a deeper structural issue: no design
            system underpinning the function, plus design-to-development handover that lacked the
            structure needed to ship at pace. Designs were being interpreted rather than
            implemented, leading to noticeable rework cycles.
          </p>
          <p>
            <strong>The internal users were analysts, not executives</strong> — power users living
            inside these dashboards every working day. That changes the design problem
            fundamentally. Executive dashboards are about clarity at a glance; analyst dashboards
            are about density, speed, signal precision, and time-to-insight. The engagement scope
            widened to three parallel tracks: building the analytics design system from zero,
            shipping dashboards across the five data domains, and raising the team's data viz
            maturity so the practice survived past my contract.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Designing for internal analysts is a different discipline from designing for clients
              — and a team that hasn't worked at that depth before needs both the system to
              deliver against and the practice to keep delivering.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">A tokenised analytics design system built for density, speed, and consistency</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Define a design system foundation for complex data visualisation across five
              distinct business domains, optimised for analyst power users, and maintainable by an
              established team that hadn't worked at this level of data viz depth.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cwt/slider/05.webp"
              alt="CWT product surface — Define phase"
            />
          </figure>
          <p>
            The system sat on three principles: density as a feature not a flaw, speed as a
            design property, and consistency across five different data shapes. Density first —
            analyst dashboards should not be sparse; the system was defined around dense layouts
            with strict typographic and spacing rules to keep that density legible.
            <strong>Time-to-insight was treated as a design property</strong>, not a UX
            nice-to-have: layouts put the most-consulted data in the highest-priority positions
            by default, and cross-filtering let analysts move between summary and detail without
            losing context.
          </p>
          <p>
            Consistency was the hardest principle: the five domains had genuinely different data
            shapes — time-series spend, categorical compliance, geographic risk distribution. A
            shared token foundation for colour, spacing, and typography was paired with a
            chart-pattern library that addressed each data shape with consistent visual rules.
            Figma was the source of truth; Zeplin and Storybook were defined upfront as the
            canonical handover bridge, all three kept in alignment.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              A design system for internal analysts isn't a stripped-down version of a client
              system — it's a different discipline entirely, optimised for properties (density,
              speed, daily-use ergonomics) that client systems rarely prioritise.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">Shipping dashboards while raising the team's data visualisation capability</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build and ship dashboards across the five data domains while simultaneously raising
              the in-house team's data visualisation capability and embedding a structured
              design-to-development handover practice the team could continue after engagement end.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cwt/slider/07.webp"
              alt="CWT product surface — Develop phase"
            />
          </figure>
          <p>
            Development ran in two parallel tracks: shipping production dashboards across the five
            data domains, and raising the team's data visualisation capability while shipping.
            Chart families were designed against the system token foundation — travel spend leaned
            on time-series and categorical breakdowns; traveller behaviour used compliance-state
            visualisation; sustainability needed emissions patterns designed from scratch;
            supplier performance used relational and comparative patterns; duty-of-care
            prioritised geographic and risk distribution. Each new pattern was designed to be
            reusable rather than domain-locked.
          </p>
          <p>
            The operational impact was sharpest at the handover layer. <strong>A structured Zeplin
            and Storybook practice was established as the canonical bridge between design and
            development</strong> — strict alignment between Figma, Zeplin specs, and Storybook
            implementations. Engineering picked up dashboards with substantially less
            interpretation work; components were specified once and implemented to match. The team
            was trained on the workflow during real production work, not as a separate initiative.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Raising a team's design capability in eight months is only possible if the
              upskilling happens on the same work that's shipping to production — not as a
              separate training initiative running alongside it.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">A maturing analytics function with the design foundations to keep growing</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deliver production dashboards across all five data domains, a tokenised analytics
              design system, and a structured handover practice — with the in-house team mature
              enough in data visualisation to continue extending the work after engagement end.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cwt/slider/09.webp"
              alt="CWT product surface — Deliver phase"
            />
          </figure>
          <p>
            The engagement delivered <span class="accent">dashboards and design system patterns
            shipped to production</span> for CWT's internal data and analytics teams, covering
            travel spend, traveller behaviour, sustainability, supplier performance, and
            duty-of-care reporting. The tokenised analytics design system became the foundation
            subsequent dashboards inherited from rather than reinvented.
          </p>
          <p>
            <span class="accent">The structured Zeplin and Storybook practice reduced developer
            rework noticeably across the engagement</span> — components specified once and
            implemented to match rather than re-interpreted per dashboard. Engineering velocity
            improved because the design-to-development bridge was canonical infrastructure, not
            ad-hoc documentation.
          </p>
          <p>
            The strongest long-term outcome was structural.
            <span class="accent">The in-house team continued the practice after I left</span> —
            extending the analytics design system with new dashboards, applying the data
            visualisation patterns to new business domains, and using the Zeplin/Storybook
            workflow as their standard way of working. The maturity uplift lived in shipped work
            and team practice, not in slides.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The strongest internal-product engagements are the ones where the team is more
              capable on the day the contractor leaves than the day they arrived — and where that
              capability lives in shipped work, not in slides.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>
