---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/adaptive-crm/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/adaptive-crm/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/adaptive-crm/slider/${f}`);
---

<BaseLayout
  title="AdaptiveCRM — Case Study"
  description="A solo build of an AI-native CRM for a UK luxury car dealer — reverse-matches vehicles to customers from a screenshot, photo, or WhatsApp message in under 10 seconds."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">AdaptiveCRM</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              Most dealer CRMs ask "which car suits this customer?" The real dealer workflow runs
              the other way. AdaptiveCRM inverts the model — drop a screenshot, photo, or
              WhatsApp message and the system extracts the vehicle details and ranks which
              customers in your database want it, instantly.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>Solo build (~1 week), May 2026</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">Claude</span>
              <span class="tpl-meta-chip">Claude Code</span>
              <span class="tpl-meta-chip">React</span>
              <span class="tpl-meta-chip">Vite</span>
              <span class="tpl-meta-chip">Tailwind CSS</span>
              <span class="tpl-meta-chip">Vercel</span>
              <span class="tpl-meta-chip">Claude API (Haiku 4.5)</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd class="tpl-meta-clamp">Production CRM with AI-powered reverse matching, 8-stage lead pipeline, stock management, financial dashboard, and social post generation</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd class="tpl-meta-clamp">~70% reduction in vehicle-to-customer matching time, under £0.005 per AI lookup, three input methods in one unified import interface</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="/work/cubik-crm" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="#" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class={`tpl-content ${sliderImages.length === 0 ? 'is-empty-slider' : ''}`}>
        {sliderImages.length > 0 && (
          <div class="tpl-slider" data-slider data-autoplay="8000">
            <div class="tpl-slider-track" data-slider-track>
              {sliderImages.map((src, i) => (
                <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                  <img
                    src={src}
                    alt={`Slide ${i + 1}`}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    data-lightbox="checkrr"
                  />
                </div>
              ))}
            </div>

            {sliderImages.length > 1 && (
              <>
                <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M15 18l-6-6 6-6" />
                  </svg>
                </button>
                <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </button>
                <div class="tpl-slider-dots" data-slider-dots>
                  {sliderImages.map((_, i) => (
                    <button
                      type="button"
                      class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                      data-slide-index={i}
                      aria-label={`Go to slide ${i + 1}`}
                    ></button>
                  ))}
                </div>
              </>
            )}
          </div>
        )}

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">The brief was wrong — and catching that early was the whole game</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              A UK luxury car dealer was running their sales operation across spreadsheets,
              WhatsApp threads, and phone notes. Leads were missed. Stock was found but never
              matched to the right customer. No one had visibility of pipeline value or team
              performance. The brief was to build a CRM.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/adaptive-crm/slider/avs-07-leads-list.webp"
              alt="AdaptiveCRM leads list — the legacy customer-pipeline view"
            />
          </figure>
          <p>
            The brief arrived as a standard CRM build — pipeline, stock, customers. Straightforward
            enough. But during the first scoping conversation, a specific pain point surfaced that
            reframed everything: <strong>brokers find cars constantly, but have no fast way to
            find which customer wants them.</strong>
          </p>
          <p>
            The workflow was: spot a vehicle on AutoTrader, retype all the details into a
            spreadsheet, manually search through every customer record, try to remember which one
            mentioned they wanted a grey SUV six months ago. Half the time it didn't happen at
            all. Matches were missed not because the data didn't exist, but because searching it
            manually was too slow and too unreliable.
          </p>
          <p>
            The conventional CRM direction — "I have a customer, find them a car" — wasn't the
            problem worth solving. Every CRM on the market does that. The real workflow was the
            opposite: "I found a car, who wants it?" Dealers browse AutoTrader continuously. They
            receive WhatsApp messages about available stock. They photograph vehicles at auctions.
            In each case the question is always the same: which of my customers would want this?
            That inversion — caught in the first hour before any code was written — became the
            entire product.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The brief is a hypothesis, not a specification. Pushing on the actual workflow before
              starting to design revealed the more valuable problem. A standard CRM build would
              have been finished and forgotten.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">One interface for every source a dealer finds a car</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build a reverse-matching system that works regardless of how a dealer finds a
              vehicle — AutoTrader browsing, auction forecourt photos, forwarded WhatsApp messages
              — and ranks customers from the existing database by relevance, without requiring any
              manual data re-entry.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/adaptive-crm/slider/avs-03-matches-import-upload.webp"
              alt="AdaptiveCRM unified import modal — URL, screenshot, and text/chat tabs"
            />
          </figure>
          <p>
            The definition phase converged on one core decision: <strong>the import interface must
            accept unstructured input as a first-class method.</strong> Dealers don't find cars in
            one place. They find them on AutoTrader pages, in photos taken on their phone, in
            messages forwarded from contacts. Any tool that only worked with structured data — a
            URL or a form — would fail for a significant proportion of real-world usage.
          </p>
          <p>
            The solution was a single import modal with three tabs: URL (AutoTrader scraping),
            screenshot (Claude vision extraction), and text/chat (free-form paste from WhatsApp,
            email, SMS, forum posts). Each input method produces the same canonical JSON — make,
            model, year, mileage, colour, price, seller, specs — which feeds the same matching
            engine and the same preview UI. Dealers don't think about how they found the car. They
            just import it.
          </p>
          <p>
            The matching logic was designed around a weighted scoring system: make match (40pts),
            budget match (20pts), body type (15pts), mileage under threshold (15pts), feature tag
            overlap (10pts). Customer preferences — desired makes, body types, budget range, max
            mileage, feature interests — are stored against each customer record and scored
            against every imported vehicle. The top matches surface ranked by score, each with a
            plain-English explanation of why they matched and a "Log interest" action that writes
            directly to their open lead.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Unification beats feature multiplication. The import tool could have been three
              separate features. Making it one modal with three tabs reduced cognitive load,
              eliminated design duplication, and meant the AI extraction output only needed to be
              designed once.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">AI extraction at half a penny per lookup</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build the three-input extraction pipeline, implement the scoring engine against the
              customer database, surface ranked matches with score breakdown and contact actions,
              and handle the full edge case set — vehicles already in stock, customers with no
              preferences set, low-confidence extractions.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/adaptive-crm/slider/avs-01-matches-import-extracted.webp"
              alt="AdaptiveCRM extraction output — canonical JSON ready for matching"
            />
          </figure>
          <p>
            Development centred on the extraction pipeline. Each input method routes to a
            dedicated Vercel serverless function calling Claude Haiku 4.5. The screenshot endpoint
            sends the base64 image with a structured prompt instructing Claude to return only
            valid JSON — make, model, year, mileage, colour, price, seller name, seller phone,
            rating, CO₂, tax, finance monthly, confidence score, extraction quality. The text
            endpoint sends the raw pasted content with the same output schema. <strong>Both methods
            produce identical canonical JSON</strong>, feeding the same downstream matching and
            preview components.
          </p>
          <p>
            Client-side image processing handles a practical constraint: AutoTrader screenshots
            frequently exceed Anthropic's 5MB ceiling and blow the aspect-ratio limit. Images are
            downscaled before dispatch, and a square top-crop thumbnail is generated for the
            preview panel — showing the vehicle, not the page footer.
          </p>
          <p>
            The matching engine scores every customer in the database against the extracted
            vehicle spec and returns the top six, ranked. Each match card shows customer name,
            status, owner, last contact, preference tags, and a percentage score. Clicking a match
            opens the match detail page: a scored breakdown by criterion (bar chart per category,
            points earned vs maximum), a plain-English summary ("Kerem has been looking for a
            Lamborghini SUV in the £120–200k range — this vehicle hits every preference"), contact
            history for this specific match, a log-action panel (Called / Emailed / No answer /
            Not interested), and a customer sidebar with their full preference profile and links
            to their record and open lead.
          </p>
          <p>
            Stock deduplication runs automatically — if the extracted vehicle matches an existing
            stock record by make, model, year, and colour, a banner fires on the preview screen
            before the dealer takes any action.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Designing the match detail page around explainability — showing <em>why</em> a
              customer matched, not just that they did — changed how dealers use the feature.
              "This car hits every one of your criteria" is a stronger opening to a call than
              anything a generic CRM surfaces.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">Screenshot to ranked customers in under 10 seconds</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deploy the extraction and matching pipeline, validate accuracy across the three
              input methods, measure end-to-end time from import to match display, and confirm the
              workflow replaces manual searching rather than sitting alongside it.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/adaptive-crm/slider/avs-04-matches-list.webp"
              alt="AdaptiveCRM matches page — ranked customers per imported vehicle"
            />
          </figure>
          <p>
            Deployment validated the core hypothesis. The end-to-end workflow — drop screenshot,
            extraction runs, ranked matches appear, dealer clicks contact — replaced the previous
            manual process: find vehicle, retype details, search customer database, try to recall
            preferences, call. <span class="accent">Previous workflow: ~10 minutes</span> per
            discovered vehicle. <span class="accent">With import and matching: under 3 minutes.</span>
            <span class="accent">Estimated saving: 5+ hours per week</span> across the sales team
            once embedded in daily use.
          </p>
          <p>
            Extraction cost came in at <span class="accent">£0.001–0.005 per import</span> (Claude
            Haiku 4.5) — marginal at any realistic usage volume, with no infrastructure overhead
            beyond the existing Vercel deployment. The three input methods cover the full range of
            real-world sourcing channels: AutoTrader URL scraping handles structured browsing,
            screenshot handles listing pages and mobile captures, text/chat handles WhatsApp
            forwards and messaged descriptions. <strong>Dealers stopped asking which method to
            use</strong> — the unified interface meant they just imported regardless of source.
          </p>
          <p>
            The shipped update confirmed the workflow inversion: the Matches page, not the lead
            pipeline, became the first thing the sales team opened each morning. The pipeline,
            dashboard, stock wizard, financial intelligence, and social post generator all shipped
            as supporting features. The matching engine was the product.
          </p>
          <p>
            Three of the four originally planned import actions (competitor pricing tracking,
            market intelligence, seller contact workflow) were deliberately deferred at launch.
            Each required a new data schema. The decision: ship the extraction and matching core,
            observe how dealers actually use it, then design the adjacent actions against real
            usage patterns rather than assumed ones. The <code>social_posts</code> stub was
            written to the stock record schema at build time — ready to wire when usage validates
            the need.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Deferring the right things is product management. A well-documented "not now" list —
              with rationale per item — is as valuable as the shipped feature set. The deferred
              actions will be better designed for having been deferred.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>
