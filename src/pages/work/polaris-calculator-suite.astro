---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/polaris-calculator-suite/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/polaris-calculator-suite/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/polaris-calculator-suite/slider/${f}`);
---

<BaseLayout
  title="Polaris Calculator Suite — Case Study"
  description="A standalone mortgage calculator platform built for MFS — production-ready bridging and buy-to-let calculators outside Salesforce, embeddable via Visualforce when needed."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">Polaris</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              Polaris is a standalone mortgage calculator platform built for Market Financial
              Solutions (MFS) to regain delivery control after delays in a Salesforce-native
              implementation. The platform delivers production-ready bridging and buy-to-let
              calculators outside Salesforce, while remaining fully embeddable into Salesforce
              via secure Visualforce integration.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>Phase 1: standalone platform delivery. Phase 2: Salesforce Visualforce embedding and API integration.</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">React</span>
              <span class="tpl-meta-chip">Vite</span>
              <span class="tpl-meta-chip">Node.js</span>
              <span class="tpl-meta-chip">Express</span>
              <span class="tpl-meta-chip">JavaScript</span>
              <span class="tpl-meta-chip">Azure</span>
              <span class="tpl-meta-chip">Salesforce Visualforce</span>
              <span class="tpl-meta-chip">Apex</span>
              <span class="tpl-meta-chip">Microsoft Entra ID</span>
              <span class="tpl-meta-chip">Azure DevOps</span>
              <span class="tpl-meta-chip">Jest</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd class="tpl-meta-clamp">Production-ready calculator suite delivering indicative quotes, configurable rate management, API-driven architecture, and Salesforce integration capability without locking business logic into Salesforce.</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd class="tpl-meta-clamp">Standalone delivery ahead of Salesforce dependency, sub-60-second configuration propagation, reusable calculator logic across web and Salesforce channels, reduced operational dependency on Salesforce delivery timelines.</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="/work/cubik-crm" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="#" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class={`tpl-content ${sliderImages.length === 0 ? 'is-empty-slider' : ''}`}>
        {sliderImages.length > 0 && (
          <div class="tpl-slider" data-slider data-autoplay="8000">
            <div class="tpl-slider-track" data-slider-track>
              {sliderImages.map((src, i) => (
                <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                  <img
                    src={src}
                    alt={`Slide ${i + 1}`}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    data-lightbox="checkrr"
                  />
                </div>
              ))}
            </div>

            {sliderImages.length > 1 && (
              <>
                <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M15 18l-6-6 6-6" />
                  </svg>
                </button>
                <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M9 6l6 6-6 6" />
                  </svg>
                </button>
                <div class="tpl-slider-dots" data-slider-dots>
                  {sliderImages.map((_, i) => (
                    <button
                      type="button"
                      class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                      data-slide-index={i}
                      aria-label={`Go to slide ${i + 1}`}
                    ></button>
                  ))}
                </div>
              </>
            )}
          </div>
        )}

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">Breaking dependency on delayed Salesforce delivery</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              The business needed production-ready mortgage calculators, but delivery was
              constrained by Salesforce implementation complexity and dependency on external
              delivery timelines. Waiting for a Salesforce-native solution risked delaying
              product rollout, internal adoption, and broker usability improvements.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/polaris-calculator-suite/slider/03.webp"
              alt="Polaris product surface — Discover phase"
            />
          </figure>
          <p>
            Discovery exposed the wider operational issue: <strong>the business had become
            dependent on Salesforce delivery velocity</strong> for core commercial tooling.
            Calculators were treated as Salesforce features rather than standalone lending
            products, creating bottlenecks around deployment, testing, and iteration.
          </p>
          <p>
            The insight was to reverse the architecture model completely. Instead of building
            inside Salesforce, Polaris would operate as an independent platform with Salesforce
            acting as a container layer later through Visualforce embedding. This removed platform
            dependency while preserving future integration capability. The project became a
            sidecar architecture strategy: independent execution with integrated experience.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The real risk wasn't delayed Salesforce delivery — it was coupling commercial
              agility to a single enterprise platform release cycle.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">API-first calculators with Salesforce as presentation layer</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Define an architecture that allows calculators to run independently while still
              integrating securely into Salesforce through Visualforce, Apex, and API
              orchestration.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/polaris-calculator-suite/slider/05.webp"
              alt="Polaris product surface — Define phase"
            />
          </figure>
          <p>
            The definition phase focused on architectural boundaries. <strong>Core principle:
            business logic never lives inside Salesforce</strong>. Polaris would own calculations,
            configuration, validation, and rate logic externally, while Salesforce would consume
            outputs and orchestrate workflow actions.
          </p>
          <p>
            The stack was deliberately modern and modular: React for dynamic interfaces, Vite for
            fast builds, Node.js / Express for secure APIs, Azure hosting and CI/CD. Salesforce
            integration used Visualforce as iframe container, Apex for authentication, OAuth/JWT
            connected apps for encrypted communication, and REST APIs for quote exchange.
            Configuration management became centralized with API-driven distribution, allowing
            commercial teams to adjust rates and criteria without engineering releases.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Treating Salesforce as an orchestration layer rather than the runtime engine
              dramatically simplified both delivery risk and long-term maintainability.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">Live configurable calculators outside Salesforce runtime constraints</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build production-grade calculators with dynamic rate logic, configurable lending
              criteria, responsive UI behaviour, and secure Salesforce integration — while
              ensuring the platform remains independently deployable.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/polaris-calculator-suite/slider/07.webp"
              alt="Polaris product surface — Develop phase"
            />
          </figure>
          <p>
            Development separated calculator intelligence from presentation channels. React front
            end handled interactive quote journeys — sliders, LTV calculations, stress testing,
            product tiering — while Node.js APIs centralized lending logic. The architecture
            intentionally <strong>mirrored enterprise platform behaviour without inheriting
            Salesforce runtime limitations</strong>.
          </p>
          <p>
            Visualforce integration allowed Polaris to appear natively inside Salesforce while
            remaining externally hosted, preserving performance and deployment independence. A
            major operational improvement: product teams could update rates, lending caps, product
            availability, stress rates, and criteria rules without code deployments. This changed
            the release model from "scheduled software release" to "controlled commercial
            configuration."
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The biggest technical advantage came from decoupling calculator logic from
              enterprise platform constraints — not from the UI itself.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">Production-ready fallback platform delivered ahead of enterprise dependency</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deploy Polaris as a production-ready fallback platform capable of supporting
              standalone usage immediately while validating Salesforce embedding, configuration
              propagation, and operational scalability.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/polaris-calculator-suite/slider/09.webp"
              alt="Polaris product surface — Deliver phase"
            />
          </figure>
          <p>
            Polaris validated the sidecar delivery model successfully. The platform launched as a
            <span class="accent">fully operational standalone calculator suite</span> while
            retaining a clear path into Salesforce through Visualforce.
            <span class="accent">Delivery completed ahead of Salesforce-native timelines</span>,
            allowing the business to regain operational momentum without abandoning future
            integration goals.
          </p>
          <p>
            Production demonstrated standalone Azure hosting, secure Salesforce API communication,
            embeddable Visualforce experience, live product configuration updates, and reusable
            calculation logic across channels. <strong>The biggest shift was psychological rather
            than technical</strong>: internal stakeholders moved away from assuming all lending
            tooling must live entirely inside Salesforce. Unexpectedly, the fallback platform
            evolved into a stronger long-term position by externalising the lending engine.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Fallback architecture can become strategic architecture when it removes dependency
              bottlenecks and improves delivery velocity across the organisation.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>
