---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/cubik-ai/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/cubik-ai/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/cubik-ai/slider/${f}`);
---

<BaseLayout
  title="Cubik AI — Case Study"
  description="A solo, AI-native build of a conversational quote engine for specialist property finance brokers — natural-language enquiries to indicative quotes in under 60 seconds. Built with Claude, Next.js, and pure-function quote engines."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">Cubik AI</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              Most broker quote tools force natural language enquiries through rigid forms.
              Cubik AI inverts that — brokers type "bridging loan for refurb exit, 70% LTV" and
              get an indicative quote in under 60 seconds, no LTV calculation, no rate card
              lookup, no spreadsheet.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>Solo build, iterative development (AI-native from inception)</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">Claude Code</span>
              <span class="tpl-meta-chip">Claude API</span>
              <span class="tpl-meta-chip">Next.js 14</span>
              <span class="tpl-meta-chip">TypeScript</span>
              <span class="tpl-meta-chip">Tailwind CSS</span>
              <span class="tpl-meta-chip">Upstash Redis</span>
              <span class="tpl-meta-chip">Neon Postgres</span>
              <span class="tpl-meta-chip">Resend</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd>Production platform serving real broker enquiries at cubikcommercial.co.uk</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd>Sub-60s quote generation, 80% classification accuracy, 95%+ time reduction vs manual calculation</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="#" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="/work/cubik-crm" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class="tpl-content">
        <div class="tpl-slider" data-slider data-autoplay="8000">
          <div class="tpl-slider-track" data-slider-track>
            {sliderImages.map((src, i) => (
              <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                <img
                  src={src}
                  alt={`Slide ${i + 1}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  data-lightbox="checkrr"
                />
              </div>
            ))}
          </div>

          {sliderImages.length > 1 && (
            <>
              <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M15 18l-6-6 6-6" />
                </svg>
              </button>
              <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M9 6l6 6-6 6" />
                </svg>
              </button>
              <div class="tpl-slider-dots" data-slider-dots>
                {sliderImages.map((_, i) => (
                  <button
                    type="button"
                    class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                    data-slide-index={i}
                    aria-label={`Go to slide ${i + 1}`}
                  ></button>
                ))}
              </div>
            </>
          )}
        </div>

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">Understanding the broker's manual calculation burden</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Specialist property finance brokers spend 15–30 minutes per quote manually
              calculating LTV, ICR, and eligibility across 50+ lender criteria matrices. Errors
              creep in during manual calculation — transposed digits, incorrect ICR formulas,
              outdated rate assumptions.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-ai/slider/02.png"
              alt="Cubik AI product surface — Discover phase"
            />
          </figure>
          <p>
            Three decades of industry experience revealed the same workflow loop: receive enquiry,
            open spreadsheet, calculate LTV manually, cross-reference lender rate cards, check
            property type eligibility. This 15–30 minute process happens dozens of times per week.
          </p>
          <p>
            <strong>Existing solutions were inadequate</strong> — traditional broker CRMs lacked
            intelligent quoting, generic mortgage platforms didn't handle specialist lending
            complexity (bridging, commercial BTL nuances), and lender portals required separate
            logins just for indicative quotes. The core insight: brokers think in natural language
            ("bridging loan for refurb exit, 70% LTV") but were forced to translate that into
            rigid form fields.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The friction wasn't calculation complexity — it was the translation layer between
              natural language client enquiries and structured quote inputs, plus the cognitive
              load of tracking 50+ lender criteria rules simultaneously.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">Making AI the orchestration layer, not the calculator</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build a conversational interface that accepts natural language enquiries, infers
              product line intent (Rental BTL vs Bridging), and delivers accurate indicative
              quotes in under 60 seconds — without requiring upfront product selection.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-ai/slider/04.png"
              alt="Cubik AI product surface — Define phase"
            />
          </figure>
          <p>
            The breakthrough was inverting the model: <strong>make conversation the primary
            interface</strong>, not a secondary help feature. Three core decisions emerged: Claude
            as product component (tool-use loop orchestrates quote calculation), conversational
            product-line classification (infers Rental vs Bridging from keywords like "refurb,"
            "rental income," "tenanted"), and pure-function quote engines separated from AI
            (deterministic pricing logic that Claude calls via tools).
          </p>
          <p>
            Scope constraints: indicative quotes only, two product lines, email-based illustration
            delivery. The system needed to feel like talking to an expert broker, not filling out
            a form supervised by a chatbot.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              "AI-native" doesn't mean "AI does everything" — it means AI handles orchestration
              and natural language understanding while deterministic functions handle business
              logic that can't tolerate LLM unpredictability.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">Building reliable classification without over-classifying</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Implement Claude tool-use orchestration, build product-line classification that
              knows when it's uncertain, integrate pure-function quote engines with 50+
              configurable criteria, and deliver professional PDF illustrations — all with
              sub-60-second response times.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-ai/slider/06.png"
              alt="Cubik AI product surface — Develop phase"
            />
          </figure>
          <p>
            The classifier runs on every user message, evaluating conversational cues and setting
            a confidence threshold (<code>PRODUCT_LINE_CONFIDENCE_THRESHOLD</code>) that triggers
            fallback buttons after two failed inferences. This <strong>prevented
            over-classification</strong> — forcing a choice when uncertain rather than guessing
            wrong.
          </p>
          <p>
            Quote engines are pure functions: BTL applies credit tier rates + product increments +
            property loadings with LTV caps and ICR floors; Bridging uses per-subtype overrides.
            Both source configuration from Redis (<code>admin-config:v1</code>) with 60-second
            edge caching, allowing admin rate changes without code deploys. The email illustration
            system fires on quote completion via Resend. Honeypot anti-spam and Upstash rate
            limiting (10/hour per IP) rounded out the production-ready stack.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              LLM orchestration works when business logic lives in deterministic functions —
              Claude handles "what does the user want" while pure functions handle "here's the
              exact answer," preventing hallucinated pricing.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">Validating conversational classification in production</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deploy production quote engine, validate sub-60-second response times, measure
              classification accuracy against explicit fallback rate, and confirm quote engine
              accuracy against manual broker calculations.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-ai/slider/08.png"
              alt="Cubik AI product surface — Deliver phase"
            />
          </figure>
          <p>
            Production deployment to Vercel validated core hypotheses:
            <span class="accent">80% conversational classification accuracy</span> (fallback
            buttons for ambiguous cases like "buy-to-let bridging"),
            <span class="accent">20–30 second average completion time</span> including Claude API
            round-trip and PDF generation, and quote engine accuracy confirmed against manual
            spreadsheet calculations by experienced brokers.
          </p>
          <p>
            User feedback revealed <strong>unexpected artifacts</strong> — brokers forwarded chat
            transcripts to clients because the conversation captured context better than
            standalone quotes, and email illustration PDFs became client-facing deliverables
            rather than internal records. Manual deploy via <code>vercel --prod --yes</code> with
            row-count parity checks ensures no data loss during schema changes.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Conversational interfaces create unexpected artifacts — the chat transcript itself
              became a valuable deliverable for client communication, not just a means to
              generate a quote.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>

<style>
  /* cubik-ai figures: contain (not crop) — screenshots vary in aspect ratio. */
  .tpl-figure {
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tpl-figure img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    object-fit: contain;
  }
</style>
