---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/work-detail.css';

// Hero slider — enumerate /public/case-studies/cubik-crm/slider/ at build time.
import fs from 'node:fs';
const sliderDir = './public/case-studies/cubik-crm/slider';
const sliderImages = fs
  .readdirSync(sliderDir)
  .filter((f) => /\.(webp|png|jpe?g)$/i.test(f))
  .sort()
  .map((f) => `/case-studies/cubik-crm/slider/${f}`);
---

<BaseLayout
  title="Cubik CRM — Case Study"
  description="A solo build of a pipeline kanban with pure-function heat scoring and auto-promotion from a Cubik AI lead — built with Claude Code, Next.js, and @dnd-kit."
>
  <div class="cursor-glow" id="cursorGlow"></div>

  <div class="wrap">
    <Nav variant="detail" />

    {/* BODY — 2-col: sticky meta left, image-rich content right */}
    <div class="tpl-layout">
      <aside class="tpl-meta">
        <div class="tpl-meta-titlerow">
          <h2 class="tpl-meta-title">Cubik CRM</h2>
          <button class="tpl-meta-link" type="button" data-copy-link aria-label="Copy link to this case study">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 1 0-7.07-7.07l-1 1" />
              <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 1 0 7.07 7.07l1-1" />
            </svg>
            <span class="tpl-meta-link-feedback" aria-hidden="true">Copied</span>
          </button>
        </div>

        <dl class="tpl-meta-list">
          <div class="tpl-meta-row">
            <dt>Summary</dt>
            <dd>
              Most broker CRMs require switching between quote tools and pipeline tracking. Cubik
              CRM embeds the AI quote engine directly — brokers generate indicative quotes, manage
              leads, and track pipeline progression in one unified admin tooling suite.
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Timeline</dt>
            <dd>2 weeks (solo build)</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Tools</dt>
            <dd class="tpl-meta-chips">
              <span class="tpl-meta-chip">Figma</span>
              <span class="tpl-meta-chip">Claude Code</span>
              <span class="tpl-meta-chip">Next.js 14</span>
              <span class="tpl-meta-chip">TypeScript</span>
              <span class="tpl-meta-chip">@dnd-kit</span>
              <span class="tpl-meta-chip">Upstash Redis</span>
              <span class="tpl-meta-chip">Neon Postgres</span>
              <span class="tpl-meta-chip">Drizzle ORM</span>
            </dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Outcome</dt>
            <dd class="tpl-meta-clamp">Production admin suite with embedded quote generation, leads management, pipeline kanban, support ticketing</dd>
          </div>
          <div class="tpl-meta-row">
            <dt>Key metrics</dt>
            <dd class="tpl-meta-clamp">Single interface for quote-to-close workflow, auto-promotion from leads to pipeline, configurable rate/criteria administration</dd>
          </div>
        </dl>

        <nav class="tpl-pn" aria-label="Project navigation">
          <a href="/work/cubik-ai" class="tpl-pn-link tpl-pn-prev">
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M21 5H1M6 1L1 5l5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <span class="tpl-pn-label">Prev.</span>
          </a>
          <a href="#" class="tpl-pn-link tpl-pn-next">
            <span class="tpl-pn-label">Next</span>
            <svg width="18" height="10" viewBox="0 0 22 10" fill="none" aria-hidden="true">
              <path d="M1 5h20M16 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </nav>
      </aside>

      <div class="tpl-content">
        <div class="tpl-slider" data-slider data-autoplay="8000">
          <div class="tpl-slider-track" data-slider-track>
            {sliderImages.map((src, i) => (
              <div class={`tpl-slide ${i === 0 ? 'is-active' : ''}`} data-slide>
                <img
                  src={src}
                  alt={`Slide ${i + 1}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  data-lightbox="checkrr"
                />
              </div>
            ))}
          </div>

          {sliderImages.length > 1 && (
            <>
              <button class="tpl-slider-btn tpl-slider-prev" type="button" data-slider-prev aria-label="Previous slide">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M15 18l-6-6 6-6" />
                </svg>
              </button>
              <button class="tpl-slider-btn tpl-slider-next" type="button" data-slider-next aria-label="Next slide">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M9 6l6 6-6 6" />
                </svg>
              </button>
              <div class="tpl-slider-dots" data-slider-dots>
                {sliderImages.map((_, i) => (
                  <button
                    type="button"
                    class={`tpl-slider-dot ${i === 0 ? 'is-active' : ''}`}
                    data-slide-index={i}
                    aria-label={`Go to slide ${i + 1}`}
                  ></button>
                ))}
              </div>
            </>
          )}
        </div>

        {/* DOUBLE DIAMOND — headers are siblings inside .tpl-phases so they
            can stack-stick at progressive top offsets. */}
        <div class="tpl-phases">
        <a class="tpl-phase-head" href="#phase-01" style="--phase-index: 0">
          <span class="tpl-phase-num">01</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Discover</span>
        </a>
        <div class="tpl-phase-body" id="phase-01">
          <h2 class="tpl-phase-title">Eliminating context-switching between quote tools and CRM</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Brokers juggle separate tools for quote generation, lead tracking, and pipeline
              management. Each context switch loses momentum — open quote tool, copy data to CRM,
              email client, update spreadsheet. By the time they reach "contacted" status, the
              quote context is buried in email threads.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-crm/slider/02.webp"
              alt="Cubik CRM product surface — Discover phase"
            />
          </figure>
          <p>
            Industry experience revealed the fragmentation problem: <strong>brokers generated
            quotes in one system, tracked leads in another</strong>, and managed pipeline in
            spreadsheets. The quote engine (Cubik AI) delivered sub-60-second conversational
            quotes — but then brokers copy-pasted enquiry details into their CRM, losing the
            quote snapshot and forcing manual data re-entry later.
          </p>
          <p>
            The insight wasn't "build another CRM" but "embed quote generation inside the admin
            tooling." Internal tools should serve the full lifecycle: initial chat enquiry → lead
            capture with quote snapshot → pipeline progression → closed deal. One interface, one
            data model, zero context-switching.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              The problem wasn't separate tools existing — it was that each tool fragmented the
              data trail, forcing brokers to reconstruct context manually when following up days
              later.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-02" style="--phase-index: 1">
          <span class="tpl-phase-num">02</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Define</span>
        </a>
        <div class="tpl-phase-body" id="phase-02">
          <h2 class="tpl-phase-title">Quote snapshot as the canonical lead record</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build admin tooling that embeds the AI quote engine, captures quote snapshots as
              lead records, provides configurable rate/criteria administration, and auto-promotes
              leads to pipeline cases when brokers initiate contact — all within a single
              interface.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-crm/slider/04.webp"
              alt="Cubik CRM product surface — Define phase"
            />
          </figure>
          <p>
            The definition phase focused on integration points rather than feature lists.
            <strong>Core decision: leads table stores full quote snapshot</strong> — LTV, ICR,
            product type, rate, monthly payment — not just contact details. When a broker changes
            status to <code>contacted</code>, the system fires <code>promoteLeadToCase</code>,
            moving the lead (with quote context intact) to the pipeline kanban.
          </p>
          <p>
            Admin configuration became the second pillar: <code>/admin/calculator/*</code> routes
            provide live rate card editing, tier-rate management, LTV/ICR limit configuration, and
            product criteria rules. Changes write to Redis <code>admin-config:v1</code> with
            60-second edge cache, enabling rate updates without code deploys. Storage architecture:
            Redis canonical (quote engine never blocks), Postgres mirror (admin queries, sorting,
            filtering).
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Quote snapshots as lead records eliminate reconstruction friction — brokers see
              "this enquiry was 70% LTV bridging at 0.89% monthly" without opening separate
              systems or searching email.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-03" style="--phase-index: 2">
          <span class="tpl-phase-num">03</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Develop</span>
        </a>
        <div class="tpl-phase-body" id="phase-03">
          <h2 class="tpl-phase-title">Admin configuration as live rate card editing</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Build leads admin table with quote snapshot display, implement
              <code>/admin/calculator/*</code> configuration routes for rate/criteria management,
              integrate auto-promotion from leads to pipeline, and ensure admin changes propagate
              to quote engine without downtime.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-crm/slider/06.webp"
              alt="Cubik CRM product surface — Develop phase"
            />
          </figure>
          <p>
            Development prioritized the admin tooling suite over visual polish. Leads table shows
            enquiry timestamp, product line (Rental/Bridging), LTV/ICR, monthly payment, and
            <code>pipelineStatus</code> (new/contacted/qualified/won/lost). <strong>Click-to-email
            on rows</strong> opens pre-composed mailto with full quote context embedded — reducing
            broker clicks from "find lead → copy details → compose email" to "click row."
          </p>
          <p>
            The <code>/admin/calculator</code> routes provide configuration UI: tier-rate matrix
            editing (credit scores → base rates), product increment sliders (HMO +0.15%, Limited
            Company +0.10%), LTV cap configuration, ICR floor thresholds, and property-type
            eligibility toggles. Auto-promotion splices into <code>PATCH /api/leads/[id]</code>:
            status change to <code>contacted</code> creates <code>PIPE-XXXXXX</code> case in
            Redis, writes Postgres mirror, removes lead from <code>/admin/leads</code> table (no
            dual-location confusion).
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Admin configuration as live rate editing changed the deployment model — brokers
              adjust rates mid-day without waiting for code deploys, and quote engine sees changes
              within 60 seconds via edge cache.
            </p>
          </aside>
        </div>

        <a class="tpl-phase-head" href="#phase-04" style="--phase-index: 3">
          <span class="tpl-phase-num">04</span>
          <span class="tpl-phase-rule" aria-hidden="true"></span>
          <span class="tpl-phase-label">Deliver</span>
        </a>
        <div class="tpl-phase-body" id="phase-04">
          <h2 class="tpl-phase-title">Single interface for quote-to-close workflow validated in production</h2>
          <aside class="tpl-callout tpl-callout-problem">
            <span class="tpl-callout-label">Problem</span>
            <p>
              Deploy production admin suite, validate quote snapshot persistence across
              lead-to-pipeline promotion, measure configuration propagation time (admin edit →
              quote engine sees change), and confirm brokers adopt the unified interface over
              separate tools.
            </p>
          </aside>
          <figure class="tpl-figure">
            <img
              src="/case-studies/cubik-crm/slider/08.webp"
              alt="Cubik CRM product surface — Deliver phase"
            />
          </figure>
          <p>
            Deployment validated the integration hypothesis: brokers generate quotes via
            <code>/</code> (public chat), view captured leads in <code>/admin/leads</code> with
            full quote context, adjust rates in <code>/admin/calculator</code>, and track promoted
            cases in <code>/admin/pipeline</code>.
            <span class="accent">Configuration propagation: sub-60s</span> (admin edit → Redis
            write → edge cache refresh).
            <span class="accent">Auto-promotion: 100% success rate</span> (no leads lost during
            status change).
          </p>
          <p>
            Broker feedback confirmed <strong>the unified interface eliminated tool-switching
            friction</strong> — "I can quote, capture, and follow up without leaving the admin
            panel." Unexpected learning: click-to-email with embedded quote context became the
            primary follow-up method (not phone), as brokers forwarded pre-composed emails with
            rate/LTV/payment details already formatted. The support ticketing system
            (<code>/admin/support</code>) rounded out the internal tooling suite with
            <code>SUP-XXXXXX</code> IDs and assignment workflows.
          </p>
          <aside class="tpl-learning">
            <span class="tpl-learning-label">What I learned</span>
            <p>
              Unified internal tooling beats best-of-breed integrations — brokers valued
              "everything in one place" over "best individual tools connected via API," even when
              feature parity wasn't perfect.
            </p>
          </aside>
        </div>
        </div>

      </div>
    </div>

  </div>

  <Footer />
</BaseLayout>


<script>
  import '../../scripts/lightbox.ts';

  // Copy-link button — copies the current page URL to the clipboard and flashes "Copied".
  document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('is-copied');
        window.setTimeout(() => btn.classList.remove('is-copied'), 1600);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — silently fail.
      }
    });
  });

  // SLIDER — auto-advance with pause-on-hover + manual prev/next/dots.
  // Single behaviour module; safe across multiple sliders on a page.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-slider]').forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('[data-slider-track]');
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide-index]'));
    const prev = slider.querySelector<HTMLElement>('[data-slider-prev]');
    const next = slider.querySelector<HTMLElement>('[data-slider-next]');
    if (!track || slides.length < 2) return;

    const autoplayMs = Number(slider.dataset.autoplay ?? 0);
    let current = 0;
    let timer: number | null = null;

    const render = () => {
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    };

    const goTo = (i: number) => {
      current = (i + slides.length) % slides.length;
      render();
    };

    const start = () => {
      if (!autoplayMs || reduceMotion) return;
      stop();
      timer = window.setInterval(() => goTo(current + 1), autoplayMs);
    };
    const stop = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    prev?.addEventListener('click', () => { goTo(current - 1); start(); });
    next?.addEventListener('click', () => { goTo(current + 1); start(); });
    dots.forEach((dot) =>
      dot.addEventListener('click', () => {
        const idx = Number(dot.dataset.slideIndex ?? 0);
        goTo(idx);
        start();
      }),
    );

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    render();
    start();
  });
</script>
