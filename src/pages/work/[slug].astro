---
import { getCollection, type CollectionEntry } from 'astro:content';
import CaseStudy from '../../layouts/CaseStudy.astro';

export async function getStaticPaths() {
  // Slugs that have their own static page (e.g. src/pages/work/checkrr.astro)
  // must be excluded here to avoid duplicate-route collisions at build time.
  const STATIC_SLUGS = new Set(['checkrr', 'cubik-ai', 'coincover', 'cwt']);
  const entries = await getCollection('work');
  return entries
    .filter((entry) => !STATIC_SLUGS.has(entry.slug))
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
---

<CaseStudy
  title={data.title}
  titleAccents={data.titleAccents}
  lede={data.lede}
  role={data.role}
  year={data.year}
  team={data.team}
  scope={data.scope}
  eyebrow={data.eyebrow}
  heroImage={data.heroImage}
  heroAlt={data.heroAlt}
  heroBrowserUrl={data.heroBrowserUrl}
  heroBrowserUrlAccent={data.heroBrowserUrlAccent}
  heroCaption={data.heroCaption}
  heroCaptionLabel={data.heroCaptionLabel}
  prevProject={data.prevProject}
  nextProject={data.nextProject}
>
  <Content />
</CaseStudy>
