---
import { getCollection, type CollectionEntry } from 'astro:content';
import CaseStudy from '../../layouts/CaseStudy.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
---

<CaseStudy
  title={data.title}
  titleAccents={data.titleAccents}
  lede={data.lede}
  role={data.role}
  year={data.year}
  team={data.team}
  scope={data.scope}
  eyebrow={data.eyebrow}
  heroImage={data.heroImage}
  heroAlt={data.heroAlt}
  heroBrowserUrl={data.heroBrowserUrl}
  heroBrowserUrlAccent={data.heroBrowserUrlAccent}
  heroCaption={data.heroCaption}
  heroCaptionLabel={data.heroCaptionLabel}
  prevProject={data.prevProject}
  nextProject={data.nextProject}
>
  <Content />
</CaseStudy>
